# Project-root overrides read by docker-compose for variable substitution.
# Copy to .env (gitignored) and fill in.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up -d   # picks up the new values
#
# Leave a value blank or remove the line to fall back to the compose default
# (mock providers, no API key — safe for offline / no-cost development).

# ---- Default real-provider stack: everything routes through OpenRouter ----
# OpenRouter exposes OpenAI-compatible /chat/completions AND /audio/transcriptions,
# so one key covers both STT and LLM.

STT_PROVIDER=openrouter-whisper
LLM_PROVIDER=openrouter-chat

OPENROUTER_API_KEY=
OPENROUTER_STT_MODEL=openai/whisper-large-v3
OPENROUTER_LLM_MODEL=openai/gpt-5-nano

# ---- Alternative: direct OpenAI ----
# Set STT_PROVIDER=openai-whisper, LLM_PROVIDER=openai-gpt, and provide:
# OPENAI_API_KEY=
