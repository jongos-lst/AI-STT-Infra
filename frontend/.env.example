# Public — exposed to the browser. Never put secrets here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_ENV=dev
# CSP allowlists this origin in connect-src for direct browser uploads. Leave
# blank in real prod (uses storage.googleapis.com automatically); set to the
# fake-gcs-server URL when running docker-compose.
NEXT_PUBLIC_GCS_BASE_URL=http://localhost:4443
