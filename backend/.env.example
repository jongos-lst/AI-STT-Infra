# Copy to .env (gitignored). Real secrets in Secret Manager in staging/prod.

# Runtime
APP_ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_stt

# Redis
REDIS_URL=redis://localhost:6379/0

# GCP
GCP_PROJECT_ID=ai-stt-dev
PUBSUB_EMULATOR_HOST=localhost:8085          # leave unset in staging/prod
STORAGE_EMULATOR_HOST=http://localhost:4443  # fake-gcs-server in dev
GCS_PUBLIC_URL=http://localhost:4443          # browser-facing — leave unset for real GCS

# Pub/Sub topic + subscription names
PUBSUB_TOPIC_STT=stt.requested
PUBSUB_TOPIC_LLM=llm.requested
PUBSUB_TOPIC_DLQ=tasks.dlq
PUBSUB_SUB_STT=stt-worker
PUBSUB_SUB_LLM=llm-worker

# Buckets
GCS_BUCKET_AUDIO=ai-stt-dev-audio
GCS_BUCKET_TRANSCRIPTS=ai-stt-dev-transcripts

# Provider selection (registry keys)
STT_PROVIDER=mock                 # openai-whisper | vertex-chirp | mock
LLM_PROVIDER=mock                 # openai-gpt | vertex-gemini | mock

# Real provider keys — leave blank in dev; pulled from Secret Manager in staging/prod
OPENAI_API_KEY=
VERTEX_LOCATION=us-central1

# Auth
JWT_AUDIENCE=ai-stt-platform
JWT_ISSUER=https://securetoken.google.com/ai-stt-dev
AUTH_DISABLED=true                # true in local dev only; default is FALSE everywhere else

# Browser CORS allowlist (JSON list). Empty default = no browser may call the API.
# Example for staging: CORS_ORIGINS=["https://stg.ai-stt.example.com"]
CORS_ORIGINS=[]

# Worker-only: the URL the Pub/Sub push subscription targets. Each worker uses
# this as the audience when verifying the OIDC bearer Pub/Sub attaches.
# Set per worker in deploy; unused locally because the emulator doesn't sign.
PUBSUB_PUSH_AUDIENCE=

# Telemetry
OTEL_SERVICE_NAME=ai-stt-api
OTEL_EXPORTER_OTLP_ENDPOINT=      # blank in dev

# Limits
MAX_AUDIO_BYTES=524288000         # 500 MB
SIGNED_URL_TTL_SECONDS=900        # 15 min
